{
	"position": "top",
	"layer": "top",
	"height": 42,
	"margin-top": 5,
	"modules-left": [
		"clock",
		"hyprland/workspaces"
	],
	"modules-center": [
		"mpris"
	],
	"modules-right": [
		"bluetooth",
		"backlight",
		"pulseaudio",
		"network",
		"battery",
		"custom/notification"
	],
	"clock": {
		"format": "{:%H:%M}",
		"format-alt": "{:%A, %d %B %Y}",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "month",
			"on-scroll": 1,
			"on-click-right": "mode"
		},
		"on-click": "gnome-calendar",
		"on-click-right": "mode"
	},
	"hyprland/workspaces": {
		"format": "{name}",
		"format-icons": {
			"1": " ï„  ",
			"2": " ï‰¨ ",
			"3": " ï„، ",
			"4": " ï†¼ ",
			"5": " ïپµ ",
			"active": " ï†’ ",
			"default": " ï„‘ "
		},
		"persistent-workspaces": {
			"*": 5, // 5 workspaces by default on every monitor
			"HDMI-A-1": 3 // but only three on HDMI-A-1
		}
	},
	"mpris": {
		"format": "{status_icon} {title} â€” {artist}",
		"format-paused": "{status_icon} {title} â€” {artist}",
		"player-icons": {
			"spotify": " ",
			"brave": " َ°–ں ",
			"firefox": " َ°ˆ¹ "
		},
		"status-icons": {
			"playing": " â–¶ ",
			"paused": " âڈ¸ ",
			"stopped": " âڈ¹ "
		},
		"max-length": 60,
		"ignored-players": [
			"firefox"
		]
	},
	"bluetooth": {
		"format": "{icon}",
		"format-connected": "َ°‚± {device_alias}",
		"format-off": "َ°‚²",
		"format-disabled": "َ°‚²",
		"format-icons": {
			"enabled": "َ°‚¯",
			"disabled": "َ°‚²"
		},
		"tooltip-format": "{controller_alias}\n{status}",
		"on-click": "blueman-manager"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": [
			"َ°ƒ‍",
			"َ°ƒں",
			"َ°ƒ "
		],
		"on-scroll-up": "brightnessctl set 5%+",
		"on-scroll-down": "brightnessctl set 5%-"
	},
	"pulseaudio": {
		"format": "{volume}% {icon}",
		"format-bluetooth": "{volume}% {icon}ïٹ”",
		"format-muted": " ï€¦ ",
		"format-icons": {
			"headphone": " ï€¥  ",
			//"hands-free": "ï–گ ",
			//"headset": "ï–گ ",
			"phone": " ï‚• ",
			"phone-muted": " î´—  ",
			"portable": " ï‚• ",
			"car": " ï†¹ ",
			"default": [
				" ï€§ ",
				" ï€¨  "
			]
		},
		"scroll-step": 1,
		"on-click": "pavucontrol",
		"ignored-sinks": [
			"Easy Effects Sink"
		]
	},
	"network": {
		"interface": "wlan0",
		"format": "{ifname}",
		"format-wifi": "{essid} ï‡« ",
		"format-ethernet": "{ipaddr}/{cidr} َ°ٹ— ",
		"format-disconnected": "", //An empty format will hide the module.
		"tooltip-format": "{ifname} via {gwaddr} َ°ٹ— ",
		"tooltip-format-wifi": "{essid} ({signalStrength}%) ï‡« ",
		"tooltip-format-ethernet": "{ifname} ïƒپ ",
		"tooltip-format-disconnected": "Disconnected",
		"max-length": 50,
		"on-click": "nm-connection-editor"
	},
	"battery": {
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{capacity}% {icon}",
		"format-icons": [
			"ï‰„ ",
			"ï‰ƒ ",
			"ï‰‚ ",
			"ï‰پ ",
			"ï‰€ "
		],
		"max-length": 25
	},
	"custom/notification": {
		"tooltip": true,
		"format": "<span size='16pt'>{icon}</span>",
		"format-icons": {
			"notification": " َ±…« ",
			"none": " َ°‚œ ",
			"dnd-notification": " َ°‚  ",
			"dnd-none": " َ°ھ“ ",
			"inhibited-notification": " َ°‚› ",
			"inhibited-none": " َ°ھ‘ ",
			"dnd-inhibited-notification": " َ°‚› ",
			"dnd-inhibited-none": " َ°ھ‘ "
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	}
}